<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.SplashController"
           fx:id="rootPane"
           style="-fx-background-color: black;"
           prefWidth="1280"
           prefHeight="720">

    <VBox fx:id="logoContainer"
          alignment="CENTER"
          spacing="20"
          opacity="0.0">

        <ImageView fx:id="logoImage"
                   fitWidth="420"
                   fitHeight="420"
                   preserveRatio="true"
                   smooth="true"/>

        <Label fx:id="subtitleLabel"
               text=""
               style="-fx-text-fill: white; -fx-font-size: 18px;
                      -fx-font-family: 'Arial'; -fx-opacity: 0.7;"
               opacity="0.0"/>
    </VBox>

    <Rectangle fx:id="blackOverlay"
               fill="black"
               opacity="1.0"
               width="1280"
               height="720"/>

</StackPane>